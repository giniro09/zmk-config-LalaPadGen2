menuconfig INPUT_IQS9151
    bool "Azoteq IQS9151 driver"
    default y
    depends on GPIO
    depends on I2C
    depends on INPUT
    depends on DT_HAS_AZOTEQ_IQS9151_ENABLED
    help
      Enable the AZOTEQ IQS9151 trackpad driver.

if INPUT_IQS9151

config INPUT_IQS9151_LOG_LEVEL
    int "IQS9151 log level"
    range 0 4
    default INPUT_LOG_LEVEL if LOG
    default 0
    help
      Log level for the IQS9151 driver module.
      0: none, 1: err, 2: wrn, 3: inf, 4: dbg.
      Defaults to INPUT_LOG_LEVEL to follow input subsystem policy.

config INPUT_IQS9151_SUPPRESS_KEY_OUTPUT
    bool "Suppress IQS9151 key/button output"
    default n
    help
      Diagnostic option that suppresses all key/button events emitted by the
      IQS9151 driver while leaving relative pointer motion intact. Use this to
      isolate unexpected click/drag behavior from the trackpad button paths.

config INPUT_IQS9151_SUPPRESS_FORCE_BUTTON_OUTPUT
    bool "Suppress IQS9151 force button output"
    default n
    help
      Diagnostic option that suppresses only Force-triggered button down/up
      output while keeping existing tap/tapdrag key paths active. Use this to
      isolate unexpected drag selection caused by the force interaction path.

config INPUT_IQS9151_FSR_DIAG_MODE
    bool "Enable IQS9151 FSR-only diagnostic mode"
    default n
    help
      Diagnostic option that lets the FSR trigger the force path without any
      active trackpad touch. In this mode the driver emits haptics and logs for
      force enter/release, but does not send Force button down/up.

config INPUT_IQS9151_INIT_PRIORITY
    int "IQS9151 init priority"
    default 80
    help
      Define the initialization priority for the IQS9151 driver.

choice INPUT_IQS9151_ROTATE
    prompt "IQS9151 rotate"
    default INPUT_IQS9151_ROTATE_0
    help
      Rotate the trackpad coordinate system (0/90/180/270).
      Currently not applied by the driver.

config INPUT_IQS9151_ROTATE_0
    bool "0"

config INPUT_IQS9151_ROTATE_90
    bool "90"

config INPUT_IQS9151_ROTATE_180
    bool "180"

config INPUT_IQS9151_ROTATE_270
    bool "270"
endchoice

config INPUT_IQS9151_RESOLUTION_X
    int "IQS9151 X resolution"
    range 0 4095
    default 2457
    help
      X Resolution (0x11E6).
      Limited to 0-4095 to match the practical 12-bit trackpad
      coordinate scale used by the device configuration.
      Currently not applied by the driver.

config INPUT_IQS9151_RESOLUTION_Y
    int "IQS9151 Y resolution"
    range 0 4095
    default 3072
    help
      Y Resolution (0x11E8).
      Limited to 0-4095 to match the practical 12-bit trackpad
      coordinate scale used by the device configuration.
      Currently not applied by the driver.

config INPUT_IQS9151_ATI_TARGETCOUNT
    int "IQS9151 ATI target count"
    range 0 1000
    default 400
    help
      Trackpad ATI Target (0x119A).
      Limited to 0-1000 to avoid unstable behavior.
      Currently not applied by the driver.

config INPUT_IQS9151_DYNAMIC_FILTER_BOTTOM_SPEED
    int "IQS9151 dynamic filter bottom speed"
    range 0 2047
    default 30
    help
      XY Dynamic Filter Bottom Speed (0x11EA).
      Limited to 0-2047 to stay within the documented trackpad count
      upper-limit scale.
      Currently not applied by the driver.

config INPUT_IQS9151_DYNAMIC_FILTER_TOP_SPEED
    int "IQS9151 dynamic filter top speed"
    range 0 2047
    default 511
    help
      XY Dynamic Filter Top Speed (0x11EC).
      Limited to 0-2047 to stay within the documented trackpad count
      upper-limit scale.
      Currently not applied by the driver.

config INPUT_IQS9151_DYNAMIC_FILTER_BOTTOM_BETA
    int "IQS9151 dynamic filter bottom beta"
    range 0 255
    default 20
    help
      XY Dynamic Filter Bottom Beta (0x11EE).
      Currently not applied by the driver.

config INPUT_IQS9151_1F_TAP_ENABLE
    bool "IQS9151 single-finger tap enable"
    default y
    help
      Enable single-finger tap detection in the driver.

config INPUT_IQS9151_1F_TAP_MAX_MS
    int "IQS9151 single-finger tap max time (ms)"
    range 1 1000
    default 250
    help
      Maximum down duration for 1F tap detection (driver-side).

config INPUT_IQS9151_1F_TAP_MOVE
    int "IQS9151 single-finger tap move threshold"
    range 1 1000
    default 50
    help
      Maximum accumulated movement for 1F tap detection (driver-side).

config INPUT_IQS9151_1F_PRESSHOLD_ENABLE
    bool "IQS9151 single-finger press/hold enable"
    default y
    help
      Enable single-finger deferred-click/drag behavior in the driver.
      Behavior: first tap presses BTN0 immediately and keeps it pressed
      while waiting for a second touch.

config INPUT_IQS9151_1F_TAPDRAG_GAP_MAX_MS
    int "IQS9151 single-finger deferred-click second-touch max time (ms)"
    range 1 1000
    default 160
    help
      Maximum time to keep BTN0 pressed after a 1F tap while waiting
      for a second touch (driver-side).

config INPUT_IQS9151_CURSOR_INERTIA_ENABLE
    bool "IQS9151 cursor inertia enable"
    default y
    help
      Enable cursor inertia (driver-side).

config INPUT_IQS9151_CURSOR_INERTIA_DECAY
    int "IQS9151 cursor inertia decay"
    range 0 1000
    default 950
    help
      Cursor inertia decay (driver-side).

config INPUT_IQS9151_CURSOR_INERTIA_RECENT_WINDOW_MS
    int "IQS9151 cursor inertia recent window (ms)"
    range 1 500
    default 60
    help
      Time window used to evaluate recent single-finger motion before
      allowing cursor inertia to start.

config INPUT_IQS9151_CURSOR_INERTIA_STALE_GAP_MS
    int "IQS9151 cursor inertia stale gap (ms)"
    range 1 500
    default 35
    help
      Maximum allowed time from the last single-finger motion sample to
      finger release for cursor inertia to start.

config INPUT_IQS9151_CURSOR_INERTIA_MIN_SAMPLES
    int "IQS9151 cursor inertia minimum recent samples"
    range 1 12
    default 2
    help
      Minimum count of recent single-finger motion samples required to
      start cursor inertia.

config INPUT_IQS9151_CURSOR_INERTIA_MIN_AVG_SPEED
    int "IQS9151 cursor inertia minimum average speed"
    range 1 500
    default 10
    help
      Minimum average recent single-finger speed required to start
      cursor inertia.

config INPUT_IQS9151_FORCE_THRESHOLD
    int "IQS9151 FSR force threshold"
    range 1 4095
    default 700
    help
      Minimum FSR delta from the touch-start baseline required to enter
      force mode.

config INPUT_IQS9151_FORCE_RELEASE_THRESHOLD
    int "IQS9151 FSR release threshold"
    range 1 4095
    default 450
    help
      Minimum FSR delta from the touch-start baseline required to stay in
      force mode after hysteresis is applied.

config INPUT_IQS9151_FORCE_BASELINE_SETTLE_MS
    int "IQS9151 FSR baseline settle window (ms)"
    range 0 200
    default 60
    help
      Short window after touch start during which the FSR baseline is allowed
      to settle with the normal finger-landing pressure ramp before force
      detection starts.

config INPUT_IQS9151_FORCE_MOVE_THRESHOLD
    int "IQS9151 force movement threshold"
    range 1 500
    default 20
    help
      Relative movement threshold used to classify a force press as a
      moving-context precision interaction.

config INPUT_IQS9151_CARET_HOLD_MS
    int "IQS9151 caret hold delay (ms)"
    range 50 1000
    default 300
    help
      Quiet time after a 1-finger force press before entering caret mode.

config INPUT_IQS9151_CARET_DEADZONE
    int "IQS9151 caret deadzone"
    range 1 500
    default 80
    help
      Distance from the caret center before directional key output starts.

config INPUT_IQS9151_CARET_REPEAT_INITIAL_MS
    int "IQS9151 caret repeat initial delay (ms)"
    range 50 1000
    default 220
    help
      Initial delay before caret mode starts repeating a direction.

config INPUT_IQS9151_CARET_REPEAT_BASE_MS
    int "IQS9151 caret repeat base interval (ms)"
    range 10 500
    default 90
    help
      Base interval used for caret repeats before force/movement speed-up.

config INPUT_IQS9151_HAPTIC_FSR_GUARD_MS
    int "IQS9151 haptic-to-FSR guard window (ms)"
    range 0 100
    default 25
    help
        Hold the last stable FSR value for a short window after haptic playback
        so mechanical coupling between the LRA and FSR does not cause false
        force transitions.

config INPUT_IQS9151_TAP_REPEAT_DIAG
    bool "IQS9151 tap haptic repeat diagnostic"
    default n
    help
        Repeats the tap haptic a few times after a tap. This is useful only
        for mechanical bring-up to check whether vibration really reaches the
        fingertip.

config INPUT_IQS9151_TAP_REPEAT_DIAG_COUNT
    int "IQS9151 tap haptic repeat diagnostic count"
    range 1 20
    default 6
    depends on INPUT_IQS9151_TAP_REPEAT_DIAG
    help
        Total number of tap haptic pulses to play when the diagnostic mode is
        enabled, including the first immediate pulse.

config INPUT_IQS9151_TAP_REPEAT_DIAG_INTERVAL_MS
    int "IQS9151 tap haptic repeat diagnostic interval (ms)"
    range 20 1000
    default 120
    depends on INPUT_IQS9151_TAP_REPEAT_DIAG
    help
        Delay between repeated tap haptic pulses in diagnostic mode.

config INPUT_IQS9151_2F_TAP_ENABLE
    bool "IQS9151 two-finger tap enable"
    default y
    help
      Enable two-finger tap detection in the driver.

